{
  "expo": {
    "name": "Nutrition App",
    "slug": "nutrition-app",
    "scheme": "nutritionapp",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "bundleIdentifier": "com.portfolio.nutritionapp"
    },
    "android": {
      "package": "com.portfolio.nutritionapp"
    },
    "plugins": [
      "./plugins/with-ios-build-workarounds",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Nutrition App to choose a nutrition-label image for on-device OCR diagnostics.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ]
  }
}
