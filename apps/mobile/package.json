{
  "name": "nutrition-mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "config:validate": "expo config --type public",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-navigation/native": "^7.0.0",
    "@tanstack/react-query": "^5.0.0",
    "expo": "^53.0.0",
    "expo-crypto": "~14.1.5",
    "expo-file-system": "~18.1.11",
    "expo-image-picker": "~16.1.4",
    "react": "19.0.0",
    "react-hook-form": "^7.0.0",
    "react-native": "0.79.6",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "~19.0.10",
    "@types/react-test-renderer": "^19.0.0",
    "jest": "^29.7.0",
    "react-test-renderer": "^19.0.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "react-native",
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^expo/virtual/env$": "<rootDir>/config/jestExpoEnv.js"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
