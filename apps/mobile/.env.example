# Explicit simulator development
EXPO_PUBLIC_NUTRITION_DEPLOYMENT_MODE=development
EXPO_PUBLIC_NUTRITION_API_URL=http://localhost:8000/api/v1

# For private internal/TestFlight builds, set private_single_user, an HTTPS API URL,
# and EXPO_PUBLIC_NUTRITION_PRIVATE_AUTH_TOKEN in the build environment. Never
# commit a real token; it is embedded in and extractable from the app binary.
# EXPO_PUBLIC_NUTRITION_DEPLOYMENT_MODE=private_single_user
# EXPO_PUBLIC_NUTRITION_API_URL=https://api.example.invalid/api/v1
# EXPO_PUBLIC_NUTRITION_PRIVATE_AUTH_TOKEN=

# Public production is intentionally rejected until a production identity provider exists.
