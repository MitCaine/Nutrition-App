# Required in every mode. Never omit the mode: there is no development fallback.
NUTRITION_DEPLOYMENT_MODE=development
NUTRITION_PROCESS_MODE=runtime
NUTRITION_DATABASE_URL=postgresql+psycopg://nutrition_app:nutrition_app@localhost:5432/nutrition_app
USDA_FDC_API_KEY=

# private_single_user only; inject real values outside source control.
# NUTRITION_PRIVATE_AUTH_SECRET=
# NUTRITION_PRIVATE_USER_ID=
# NUTRITION_PRIVATE_USER_EMAIL=
# NUTRITION_PRIVATE_USER_DISPLAY_NAME=Private User
# NUTRITION_PRIVATE_USER_CREATE_IF_MISSING=false

# Reserved for a future installed production authentication implementation.
# Setting a name today does not bypass the fail-closed production check.
# NUTRITION_PRODUCTION_AUTH_PROVIDER=
